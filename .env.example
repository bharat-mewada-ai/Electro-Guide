# API Configuration
PORT=3000
JWT_SECRET="your_super_secret_jwt_key_here"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Database Configuration
DATABASE_URL="file:./dev.db"

# Google Cloud Platform (GCP) Integration
# These are required for Vision OCR and Places discovery
GCP_PROJECT_ID="electro-guide-ai"
GCP_VISION_API_KEY="AIzaSyA_MOCK_KEY_FOR_EVALUATION"
GCP_PLACES_API_KEY="AIzaSyB_MOCK_KEY_FOR_EVALUATION"
GCP_SERVICE_ACCOUNT_EMAIL="gcp-vision-ocr@electro-guide-ai.iam.gserviceaccount.com"

# Legacy Google Services
GOOGLE_MAPS_API_KEY="AIzaSyC_MOCK_KEY"
GOOGLE_CALENDAR_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
